#!/bin/sh
# NanoClaw Signal Agent — Zero-install setup
# Creates a venv, installs dependencies, and runs the setup wizard.
set -e

VENV="$HOME/.nanoclaw/.venv"
REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

# Check Python
if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: Python 3 not found. Install from python.org"
    exit 1
fi

# Create venv if needed
if [ ! -f "$VENV/bin/python3" ]; then
    echo "Creating virtual environment..."
    python3 -m venv "$VENV"
fi

# Install package (editable)
echo "Installing dependencies..."
"$VENV/bin/pip" install --quiet -e "$REPO_DIR" 2>&1 | tail -1

# Run wizard
exec "$VENV/bin/python3" -m nanoclaw setup "$@"
