{
  "version": 1,
  "name": "YOUR_AGENT_NAME",

  "agents": {
    "defaults": {
      "model": "claude-sonnet-4-5",
      "fallback_model": "claude-haiku-4-5",
      "compaction": {
        "mode": "default",
        "reserveTokensFloor": 40000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 40000
        }
      },
      "session_max_tasks": 50,
      "idle_timeout": 120
    },
    "list": [
      {
        "name": "main",
        "description": "General assistant — conversation, research, planning, multi-step tasks",
        "model": "claude-sonnet-4-5",
        "workspace": "~/.nanoclaw/workspace",
        "identity_dir": "~/.nanoclaw/identity",
        "skills": [
          "coding", "research", "writing", "sysadmin",
          "github", "security", "web-browsing", "automation",
          "debugging", "deployment", "documents", "media",
          "scaffolding", "testing", "data", "handoff",
          "context-management"
        ],
        "tools": ["Read", "Write", "Edit", "Bash", "Glob", "Grep", "WebSearch", "WebFetch", "Agent"]
      },
      {
        "name": "coder",
        "description": "Code writing, debugging, testing, GitHub operations",
        "model": "claude-sonnet-4-5",
        "skills": ["coding", "github", "testing", "debugging"],
        "tools": ["Read", "Write", "Edit", "Bash", "Glob", "Grep"]
      },
      {
        "name": "writer",
        "description": "Documents, reports, content creation",
        "model": "claude-sonnet-4-5",
        "skills": ["writing", "documents", "research"],
        "tools": ["Read", "Write", "Edit", "Glob", "Grep", "WebSearch", "WebFetch"]
      },
      {
        "name": "research",
        "description": "Web research, fact-finding, source evaluation",
        "model": "claude-sonnet-4-5",
        "skills": ["research", "web-browsing"],
        "tools": ["Read", "Glob", "Grep", "WebSearch", "WebFetch"]
      }
    ]
  },

  "channels": {
    "signal": {
      "enabled": true,
      "account": "+1XXXXXXXXXX",
      "allowlist": ["+1XXXXXXXXXX"],
      "poll_interval_seconds": 5,
      "daemon_port": 19756
    }
  },

  "nodes": {
    "macmini": {
      "host": "localhost",
      "role": "primary"
    }
  },

  "mcp_servers": {
    "github": {
      "command": "gh",
      "args": ["mcp", "server"],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {}
    }
  },

  "knowledge": {
    "embedding_model": "nomic-embed-text",
    "index_paths": ["~/.nanoclaw/workspace"],
    "exclude_patterns": ["archive/", ".git/", "node_modules/", "*.db"]
  },

  "schedules": [
    {
      "name": "morning_briefing",
      "cron": "0 8 * * *",
      "agent": "main",
      "prompt": "Good morning. Check workspace health, summarize yesterday's memory log, and list any pending tasks."
    },
    {
      "name": "daily_health",
      "cron": "0 12 * * *",
      "agent": "main",
      "prompt": "Run a health check: verify disk space, check if signal-cli is responsive, verify Claude API is reachable. Report any issues."
    },
    {
      "name": "memory_cleanup",
      "cron": "0 22 * * 0",
      "agent": "main",
      "prompt": "Review memory files older than 7 days. Extract important patterns or decisions into MEMORY.md. Archive or prune stale entries."
    }
  ],

  "paths": {
    "workspace": "~/.nanoclaw/workspace",
    "logs": "~/.nanoclaw/logs",
    "sessions": "~/.nanoclaw/sessions",
    "identity": "~/.nanoclaw/identity",
    "scripts": "~/.nanoclaw/scripts"
  }
}
